---
interface Props {
  src: string;
  alt: string;
  label: string;
  variant: "AI" | "captured";
  side?: "right" | "left";
}

const { src, alt, label, variant } = Astro.props;

// User-requested colours — no matching tokens in :root; fallback hex values
const color = variant === "AI"
  ? "#7c3aed"  // bright purple — no :root token; fallback hex
  : "#16a34a"; // bright green  — no :root token; fallback hex

// Small decorative prefix icon per variant
const icon = variant === "AI" ? "✦" : "◎";
---

<figure class="ann-figure" style={`--ann-color:${color};`}>
  <img
    src={src}
    alt={alt}
    class="h-30 w-30 rounded-full object-cover border border-secondary"
  />
  <figcaption class="ann-bubble">
    <span class="ann-icon" aria-hidden="true">{icon}</span>
    {label}
  </figcaption>
</figure>

<style>
  .ann-figure {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 0;
  }

  .ann-bubble {
    position: relative;
    margin-left: 18px;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;

    /* Typography */
    font-family: var(--font-plex);
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    white-space: nowrap;
    line-height: 1;
    color: #fff;

    /* Shape */
    background: var(--ann-color);
    border-radius: 2px;
    padding: 0.45rem 0.7rem;

    /* Glow + elevation */
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.18),
      0 0 0 1px color-mix(in srgb, var(--ann-color) 80%, #000),
      0 0 18px -3px var(--ann-color),
      0 3px 8px rgba(0, 0, 0, 0.3);

    transition: box-shadow 0.25s ease, transform 0.25s ease;
    cursor: default;
  }

  /* Left-pointing tail */
  .ann-bubble::before {
    content: '';
    position: absolute;
    right: 100%;
    top: 50%;
    transform: translateY(-50%);
    width: 0;
    height: 0;
    border-top: 7px solid transparent;
    border-bottom: 7px solid transparent;
    border-right: 12px solid var(--ann-color);
  }

  /* Hover: stronger glow + slight slide */
  .ann-figure:hover .ann-bubble {
    transform: translateX(3px);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.22),
      0 0 0 1px color-mix(in srgb, var(--ann-color) 80%, #000),
      0 0 28px -2px var(--ann-color),
      0 4px 14px rgba(0, 0, 0, 0.35);
  }

  .ann-icon {
    font-size: 0.65rem;
    opacity: 0.9;
    flex-shrink: 0;
  }
</style>
