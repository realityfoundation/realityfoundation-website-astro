---
// Shared block — section (e). workingSession is the role-specific step-3 text.
// Stored as a string (may contain HTML for e.g. italic text) — rendered via set:html.

interface Props {
  workingSession?: string;
}

const {
  workingSession = "A paid practical session based on real work you'll likely do with us",
} = Astro.props;
---

<section class="sp-section">
  <h2 class="sp-heading">The selection process</h2>
  <p class="sp-lede">Four steps, about three weeks. You will know where you stand at every one of them.</p>
  <ol class="sp-list">
    <li>
      <strong>Application review</strong> A person reads it — no model screens you out.
      You hear back within 7 working days either way.
    </li>
    <li>
      <strong>Intro call (30 minutes)</strong> With the founding team. What you want,
      what we're building, whether the shapes match.
    </li>
    <li>
      <strong>Working session</strong> <Fragment set:html={workingSession} />
    </li>
    <li>
      <strong>The team (2 x 45 minutes)</strong> With the people you'd actually work
      with. Then two references.
    </li>
  </ol>
  <p class="sp-close">
    Decision within 7 working days of the last step. If it's a no, we tell
    you why. We know that's rare. It shouldn't be.
  </p>
</section>

<style>
  .sp-section {
    border-top: 1px solid var(--color-secondary);
    padding-top: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .sp-heading {
    font-family: var(--font-plex);
    font-size: 1.25rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    color: var(--color-foreground);
  }

  .sp-lede,
  .sp-close {
    font-family: var(--font-geist);
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-secondary);
    margin: 0;
  }

  .sp-list {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-family: var(--font-geist);
    font-size: 1rem;
    line-height: 1.38;
    color: var(--color-secondary);
    list-style: decimal;
    padding-left: 1.25rem;
    margin: 0;
  }

  .sp-list li {
    padding-left: 0.25rem;
  }

  .sp-list strong {
    color: var(--color-foreground);
    font-weight: 600;
  }
</style>
