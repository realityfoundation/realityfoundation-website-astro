---
// Shared block — section (d), Variant 1: non-profit, no equity.
// Salary band is derived from frontmatter props — never hardcoded.

interface Props {
  salaryMin?: number;
  salaryMax?: number;
  salaryCurrency?: string;
  salaryPeriod?: "year" | "month";
  salaryNote?: string;
}

const {
  salaryMin,
  salaryMax,
  salaryCurrency = "EUR",
  salaryPeriod = "year",
  salaryNote,
} = Astro.props;

function formatSalary(
  min?: number,
  max?: number,
  currency: string = "EUR",
  period: string = "year",
  note?: string,
): string {
  if (min === undefined) return "Salary band shared during the process";
  const sym = currency === "EUR" ? "€" : currency;
  const fmt = (n: number) => n.toLocaleString("en-US");
  let s = `${sym}${fmt(min)}`;
  if (max !== undefined) s += ` – ${sym}${fmt(max)}`;
  s += ` / ${period}`;
  if (note) s += `  ${note}`;
  return s;
}

const salary = formatSalary(salaryMin, salaryMax, salaryCurrency, salaryPeriod, salaryNote);
---

<section class="wwo-section">
  <h2 class="wwo-heading">What we offer</h2>
  <ul class="wwo-list">
    <li><strong>{salary}</strong> gross on a Belgian permanent contract. We publish the band because you should not have to negotiate blind</li>
    <li><strong>Brussels or remote</strong> Our base is Brussels, and we can hire anywhere in the EU. We also bring the team together 2 times a year, on us</li>
    <li>We currently do not offer additional benefits beyond statutory requirements</li>
    <li>25 days off plus Belgian public holidays</li>
    <li>A real budget for equipment, training, and relevant conferences</li>
    <li><strong>Your work is public</strong> What you build here stays in the open, under your name</li>
    <li>We are a non-profit. No cap table, no exit story. The upside here is impact, ownership, and building something that stays open</li>
  </ul>
</section>

<style>
  .wwo-section {
    border-top: 1px solid var(--color-secondary);
    padding-top: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .wwo-heading {
    font-family: var(--font-plex);
    font-size: 1.25rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    color: var(--color-foreground);
  }

  .wwo-list {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-family: var(--font-geist);
    font-size: 1rem;
    line-height: 1.38;
    color: var(--color-secondary);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .wwo-list li {
    padding-left: 1.25rem;
    position: relative;
  }

  .wwo-list li::before {
    content: "–";
    position: absolute;
    left: 0;
    color: var(--color-secondary);
    opacity: 0.5;
  }

  .wwo-list strong {
    color: var(--color-foreground);
    font-weight: 600;
  }
</style>
