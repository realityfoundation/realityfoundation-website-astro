---
const links = [
  { name: "Home", href: "/", target: "_self" },
  { name: "About", href: "/about", target: "_self" },
  { name: "Research", href: "/research", target: "_self" },
  { name: "Publications", href: "/publications", target: "_self" },
  { name: "Get Involved", href: "/get-involved", target: "_self" },
  { name: "Careers", href: "/careers", target: "_self" },
];
---

<header
  class="border-secondary/15 bg-background/65 fixed top-0 z-50 w-full border-b backdrop-blur-xs backdrop-saturate-150"
>
  <div class="container mx-auto flex items-center justify-between p-6">
    <a
      href="/"
      class="inline-flex items-center"
      aria-label="RealityFoundation home"
    >
      <img src="/logo.png" alt="RealityFoundation logo" class="h-10 w-auto" />
    </a>
    <nav class="text-secondary hidden items-center space-x-3 md:flex">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="hover:border-secondary pb-0.5 hover:border-b-2 hover:border-dashed"
          >
            {link.name}
          </a>
        ))
      }
      <a href="/donate" class="btn-primary ml-2 !py-0 !px-5 sm:!py-0 sm:!px-5 h-10 inline-flex items-center text-sm">Donate</a>
    </nav>
    <button
      id="menu-toggle"
      class="hamburger flex focus:outline-none md:hidden"
      aria-label="Toggle navigation"
    >
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>
  </div>
  <div
    id="menu-mobile"
    class="text-secondary bg-background hidden w-screen space-x-3 p-4 backdrop-blur-2xl md:hidden"
  >
    <nav class="flex flex-col gap-4 text-2xl">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="hover:border-secondary pb-0.5 hover:border-b-2 hover:border-dashed"
          >
            {link.name}
          </a>
        ))
      }
      <a href="/donate" class="btn-primary inline-flex items-center justify-center">Donate</a>
    </nav>
  </div>
</header>

<style>
  .hamburger {
    gap: 5px;
    cursor: pointer;
    position: relative;
    width: 24px;
    height: 21px;
    padding: 0;
    border: 0;
    background: transparent;
  }

  .hamburger-line {
    width: 24px;
    height: 3px;
    background-color: var(--color-secondary, #000000);
    transition: all 0.3s ease;
    position: absolute;
    left: 0;
  }

  .hamburger-line:nth-child(1) {
    top: 0;
  }

  .hamburger-line:nth-child(2) {
    top: 9px;
  }

  .hamburger-line:nth-child(3) {
    top: 18px;
  }

  .hamburger.active .hamburger-line:nth-child(1) {
    transform: rotate(45deg);
    top: 9px;
  }

  .hamburger.active .hamburger-line:nth-child(2) {
    display: none;
    opacity: 0;
  }

  .hamburger.active .hamburger-line:nth-child(3) {
    transform: rotate(-45deg);
    top: 9px;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const menuMobile = document.getElementById("menu-mobile");
    const toggle = document.getElementById("menu-toggle");
    toggle?.addEventListener("click", () => {
      menuMobile?.classList.toggle("hidden");
      toggle.classList.toggle("active");
      const expanded = toggle.classList.contains("active");
      toggle.setAttribute("aria-expanded", String(expanded));
    });
  });
</script>
