---
import { SITE } from "@/consts";
---


<section
    class="space-y-2 py-24"
>
    <p class="font-geist text-secondary text-sm md:text-base uppercase tracking-wider">{SITE.TITLE}</p>
    <h1
        class="heading text-[clamp(2.5rem,10vw,5rem)] uppercase"
    >
        <span id="hero-typewriter" aria-label="Don't detect AI fakes. Prevent them."></span><span class="typewriter-cursor" aria-hidden="true">|</span>
    </h1>
    <p class="text-lg md:text-xl text-secondary leading-relaxed pt-4">
        Certify your media at capture — tamper-proof, blockchain-anchored, C2PA-compliant.
    </p>
    <div class="flex flex-col md:flex-row gap-4 pt-8">
        <a
            class="btn-primary flex items-center justify-center"
            href="/donate">Donate</a
        >
        <a
            class="w-full sm:w-auto flex items-center justify-center bg-foreground text-background hover:dark:text-background rounded-2xl py-3 px-6 sm:py-4 sm:px-10 cursor-pointer hover:outline-1 hover:outline-dashed hover:outline-secondary transition"
            href="/about">About the foundation</a
        >
    </div>
</section>

<style>
    .typewriter-cursor {
        display: inline-block;
        color: var(--color-primary);
        animation: blink-cursor 0.8s step-end infinite;
        margin-left: 1px;
    }

    @keyframes blink-cursor {
        0%, 100% { opacity: 1; }
        50% { opacity: 0; }
    }
</style>

<script>
    const el = document.getElementById("hero-typewriter");
    const text = "Don't detect AI fakes. Prevent them.";
    const cursor = document.querySelector(".typewriter-cursor") as HTMLElement | null;
    let i = 0;

    function type() {
        if (!el) return;
        if (i < text.length) {
            el.textContent += text[i];
            i++;
            setTimeout(type, i === 1 ? 400 : 45);
        } else if (cursor) {
            cursor.style.animation = "blink-cursor 0.8s step-end infinite";
        }
    }

    if (cursor) cursor.style.animation = "none";
    setTimeout(type, 600);
</script>
