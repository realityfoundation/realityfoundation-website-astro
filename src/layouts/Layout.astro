---
import Head from "@/components/Head.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/consts";

import "../styles/global.css";

type Props = {
    title: string;
    description: string;
    image?: string;
    noindex?: boolean;
};

const { title, description, image, noindex = false } = Astro.props;
const pageTitle = title.includes(SITE.TITLE) ? title : `${title} | ${SITE.TITLE}`;
const canonical = new URL(Astro.url.pathname, SITE.URL).toString();
---

<!doctype html>
<html lang="en">
    <Head
        title={pageTitle}
        description={description}
        image={image}
        canonical={canonical}
        noindex={noindex}
    />
    <body class="bg-background dark:bg-background">
        <script is:inline>
            if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
                document.documentElement.classList.add("dark");
            }
        </script>
        <Header />
        <div class="min-h-screen w-full relative">
            <div
                class="fixed inset-0 -z-50 bg-background dark:bg-background dot-pattern"
            >
            </div>
            <slot />
        </div>
        <Footer />
    </body>
</html>

<style>
    .dot-pattern {
        background-image: radial-gradient(circle at 1px 1px, rgba(0, 0, 0, 0.1) 1px, transparent 0);
        background-size: 25px 25px;
    }

    @media (prefers-color-scheme: dark) {
        .dot-pattern {
            background-image: radial-gradient(circle at 1px 1px, rgba(255, 255, 255, 0.1) 1px, transparent 0);
        }
    }
</style>
