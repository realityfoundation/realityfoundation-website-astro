---
import "../styles/global.css";

interface Props {
  title: string;
  active:
    | "home"
    | "about"
    | "research"
    | "publications"
    | "blog"
    | "get-involved";
}

const { title, active } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
    <script>
      const theme = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', theme);
      window.matchMedia('(prefers-color-scheme: light)').addEventListener('change', (e) => {
        const newTheme = e.matches ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', newTheme);
      });
    </script>
  </head>
  <body>
    <div class="min-h-dvh grid" style="grid-template-rows: auto 1fr auto;">
      <header class="sticky top-0 z-100 border-b backdrop-blur-lg" style="background: color-mix(in srgb, var(--color-background) 88%, black 12%); border-color: var(--color-line);">
        <div class="mx-auto flex items-center justify-between gap-4 py-3 px-5" style="max-width: 1040px;">
          <a class="flex items-center gap-0 whitespace-nowrap font-bold text-sm uppercase tracking-wider no-underline" style="color: var(--color-accent); transition: opacity 160ms; cursor: pointer;" onmouseover="this.style.opacity='0.8'" onmouseout="this.style.opacity='1'" href="/">
            <svg
              aria-label="RealityFoundation"
              viewBox="0 0 32 32"
              width="22"
              height="22"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              style="display:inline-block;vertical-align:middle;margin-right:0.45rem"
            >
              <rect
                x="2"
                y="2"
                width="28"
                height="28"
                rx="4"
                stroke="currentColor"
                stroke-width="1.5"></rect>
              <path
                d="M8 24 L8 10 L17 10 C20.5 10 22.5 12 22.5 14.5 C22.5 17 20.5 19 17 19 L8 19"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
              <path
                d="M17 19 L23 24"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"></path>
            </svg>
            RealityFoundation
          </a>
          <nav class="main-nav flex flex-wrap items-center gap-1" aria-label="Main navigation">
            <a href="/" class={active === "home" ? "active" : ""}>Home</a>
            <a href="/about" class={active === "about" ? "active" : ""}>About</a>
            <a href="/research" class={active === "research" ? "active" : ""}>Research</a>
            <a href="/publications" class={active === "publications" ? "active" : ""}>Publications</a>
            <a href="/blog" class={active === "blog" ? "active" : ""}>Blog</a>
            <a href="/get-involved" class={active === "get-involved" ? "active" : ""}>Get Involved</a>
          </nav>
          <button
            class="nav-toggle hidden rounded-sm p-0.5"
            style="color: var(--color-muted);"
            aria-label="Toggle navigation"
            onclick="this.closest('header').querySelector('.main-nav').classList.toggle('open')"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <line x1="3" y1="6" x2="21" y2="6"></line>
              <line x1="3" y1="12" x2="21" y2="12"></line>
              <line x1="3" y1="18" x2="21" y2="18"></line>
            </svg>
          </button>
        </div>
      </header>

      <main class="mx-auto w-full px-5" style="max-width: 1040px; padding-top: 3rem; padding-bottom: 5rem;">
        <slot />
      </main>

      <footer class="border-t" style="border-color: var(--color-line); color: var(--color-muted);">
        <div class="mx-auto flex flex-wrap items-center justify-between gap-4 px-5 py-4" style="max-width: 1040px; font-size: var(--text-xs);">
          <span class="font-bold uppercase tracking-wider" style="color: var(--color-foreground);">RealityFoundation</span>
          <span class="flex gap-4">
            <a href="/about" class="no-underline transition-colors" style="color: var(--color-muted);">About</a>
            <a href="/research" class="no-underline transition-colors" style="color: var(--color-muted);">Research</a>
            <a href="/get-involved" class="no-underline transition-colors" style="color: var(--color-muted);">Get Involved</a>
          </span>
          <span style="color: var(--color-muted);">realityfoundation.eu</span>
        </div>
      </footer>
    </div>
  </body>
</html>
