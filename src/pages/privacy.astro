---
import Layout from "@/layouts/Layout.astro";
import { SITE } from "@/consts";
---

<Layout
  title="Privacy — RealityFoundation"
  description="How RealityFoundation handles personal data submitted through our website and careers pages."
  noindex={true}
>
  <div class="container mx-auto px-6 pt-18">
    <div class="space-y-12 py-12">

      <header class="space-y-4 border-b border-secondary pb-8">
        <h1 class="heading text-4xl md:text-5xl uppercase">How we handle your data</h1>
        <p class="text-secondary text-lg leading-relaxed">
          Last updated: 11 July 2026
        </p>
      </header>

      <section class="space-y-4">
        <h2 class="heading text-xl uppercase">Who we are</h2>
        <p class="text-secondary leading-relaxed">
          &lt;&lt;RealityFoundation ASBL/AISBL, address, 1000 Brussels, Belgium&gt;&gt; is the controller of the personal data you submit through this website and its careers pages.
        </p>
        <p class="text-secondary leading-relaxed">
          Questions or requests: <a href={`mailto:${SITE.EMAIL}`} class="text-primary underline underline-offset-2">{SITE.EMAIL}</a>
        </p>
      </section>

      <section class="space-y-4 border-t border-secondary pt-8">
        <h2 class="heading text-xl uppercase">Expressions of interest and job applications</h2>
        <div class="space-y-3 text-secondary leading-relaxed">
          <p>
            <strong class="text-foreground">Why we process it.</strong> To assess your expression of interest or application — GDPR Art. 6(1)(b), steps taken at your request before entering a contract. If you ask us to keep your details on file for future roles, the basis is Art. 6(1)(a), consent.
          </p>
          <p>
            <strong class="text-foreground">How long we keep it.</strong> 48 months after we receive your submission, then we delete it. You can ask us to delete it sooner at any time, without giving a reason.
          </p>
          <p>
            <strong class="text-foreground">Where it lives.</strong> In the EU, on infrastructure we control. &lt;&lt;CONFIRM once the backend is chosen.&gt;&gt;
          </p>
          <p>
            <strong class="text-foreground">No automated screening.</strong> A person reads what you send. No model decides whether you move forward.
          </p>
          <p>
            <strong class="text-foreground">Your rights.</strong> Access, correction, deletion, portability, objection — email us at <a href={`mailto:${SITE.EMAIL}`} class="text-primary underline underline-offset-2">{SITE.EMAIL}</a>. You can also lodge a complaint with the Belgian Data Protection Authority (Gegevensbeschermingsautoriteit / Autorité de protection des données) at <a href="https://www.dataprotectionauthority.be" target="_blank" rel="noopener noreferrer" class="text-primary underline underline-offset-2">dataprotectionauthority.be</a>.
          </p>
        </div>
      </section>

      <section class="space-y-4 border-t border-secondary pt-8">
        <h2 class="heading text-xl uppercase">Website usage</h2>
        <div class="space-y-3 text-secondary leading-relaxed">
          <p>
            We do not use tracking pixels, advertising cookies, or third-party analytics. We do not sell or share your data with third parties for marketing purposes.
          </p>
          <p>
            Standard server logs (IP address, browser, pages visited) are retained for &lt;&lt;X&gt;&gt; days for security purposes, then deleted.
          </p>
        </div>
      </section>

      <section class="space-y-4 border-t border-secondary pt-8">
        <h2 class="heading text-xl uppercase">Contact</h2>
        <p class="text-secondary leading-relaxed">
          For any question about this notice or about how we handle your data: <a href={`mailto:${SITE.EMAIL}`} class="text-primary underline underline-offset-2">{SITE.EMAIL}</a>
        </p>
      </section>

    </div>
  </div>
</Layout>
