---
import { getCollection, render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import { SITE } from "@/consts";
import JobMeta from "@/components/careers/JobMeta.astro";
import AboutBlock from "@/components/careers/AboutBlock.astro";
import WhatWeOfferBlock from "@/components/careers/WhatWeOfferBlock.astro";
import SelectionProcessBlock from "@/components/careers/SelectionProcessBlock.astro";

export async function getStaticPaths() {
  const jobs = await getCollection("jobs");
  return jobs.map((job) => ({
    params: { slug: job.id },
    props: { job },
  }));
}

const { job } = Astro.props;
const { Content } = await render(job);
const d = job.data;
const isRole = d.kind === "role";
const applyEmail = d.applyEmail ?? SITE.EMAIL;
const applySubject = encodeURIComponent(`Application - ${d.title}`);
const applyBody = encodeURIComponent(
  `Hi RealityFoundation team,

I am applying for the ${d.title} role.

Attached:
- CV (PDF)
- LinkedIn profile
- Relevant links (GitHub, portfolio, publications)

A short note on why this role is a fit:

Best,
[Your name]`,
);
const applyHref = `mailto:${applyEmail}?subject=${applySubject}&body=${applyBody}`;
---

<Layout
  title={`${d.title} — RealityFoundation`}
  description={d.summary}
>
  <div class="container mx-auto px-6 pt-18">
    <div class="py-12">

      <a
        href="/careers"
        class="text-secondary hover:text-primary text-sm transition-colors mb-10 inline-block"
      >
        ← Careers
      </a>

      <div class="jd-wrap max-w-4xl mx-auto">

        <!-- Page header -->
        <header class="space-y-4 pb-8 border-b border-secondary">
          <h1 class="heading text-3xl md:text-5xl uppercase">{d.title}</h1>
          <p class="text-lg text-secondary leading-relaxed">{d.summary}</p>
          {isRole && (
            <JobMeta
              team={d.team}
              locations={d.locations}
              employmentType={d.employmentType}
              salaryMin={d.salaryMin}
              salaryMax={d.salaryMax}
              salaryCurrency={d.salaryCurrency}
              salaryPeriod={d.salaryPeriod}
              salaryNote={d.salaryNote}
            />
          )}
        </header>

        <!-- Section (a): About RealityFoundation — rendered for roles only -->
        {isRole && <AboutBlock />}

        <!-- Sections (b) + (c): role-specific markdown body -->
        <div class="jd-article prose prose-neutral max-w-none">
          <Content />
        </div>

        <!-- Section (d): What we offer — rendered for roles only -->
        {isRole && (
          <WhatWeOfferBlock
            salaryMin={d.salaryMin}
            salaryMax={d.salaryMax}
            salaryCurrency={d.salaryCurrency}
            salaryPeriod={d.salaryPeriod}
            salaryNote={d.salaryNote}
          />
        )}

        <!-- Section (e): The selection process — rendered for roles only -->
        {isRole && (
          <SelectionProcessBlock workingSession={d.workingSession} />
        )}

        <!-- Bottom CTA -->
        {d.applyMode === "form" && (
          <div class="jd-cta">
            <a href={applyHref} class="btn-primary inline-block">
              Apply for this role
            </a>
          </div>
        )}
        {d.applyMode === "email" && (
          <div class="jd-cta">
            <a
              href={applyHref}
              class="btn-primary inline-block"
            >
              Apply for this role
            </a>
          </div>
        )}

      </div>
    </div>
  </div>
</Layout>

<style>
  .jd-wrap {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  /* Override the global article rule's mx-auto so it doesn't drift inside our constrained wrapper */
  .jd-article {
    max-width: none;
    margin-left: 0;
    margin-right: 0;
  }

  .jd-article {
    color: var(--color-secondary);
  }

  .jd-cta {
    display: flex;
    justify-content: flex-end;
  }
</style>
