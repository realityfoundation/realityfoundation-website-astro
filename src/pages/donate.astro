---
import Layout from "@/layouts/Layout.astro";
import { SITE } from "@/consts";
---

<Layout title="Donate | RealityFoundation" description="Support RealityFoundation's independent research on media authenticity and AI-generated counterfeits.">
    <div class="container mx-auto px-6 pt-18">
        <div class="space-y-20 py-12">
            <section class="space-y-6">
                <p class="font-geist text-secondary text-sm uppercase tracking-wider">Donate</p>
                <h1 class="heading text-4xl md:text-6xl uppercase">Support our work</h1>
                <div class="max-w-3xl space-y-4">
                    <p class="text-lg leading-relaxed text-secondary">
                        RealityFoundation is building independent infrastructure for media authenticity and protection against AI-generated counterfeits.
                    </p>
                    <p class="text-lg leading-relaxed text-secondary">
                        We are currently preparing the donations system. Secure online contributions will be available soon.
                    </p>
                </div>
                <div class="max-w-3xl rounded-lg border border-secondary p-8 space-y-4">
                    <p class="font-geist text-xs uppercase tracking-wider text-secondary">Donations</p>
                    <p class="heading text-2xl uppercase text-primary">Opening soon</p>
                    <p class="text-sm leading-relaxed text-secondary">
                        We are finalizing the donation flow to make giving simple and reliable. If you would like to support us now, contact us and we will get back to you directly.
                    </p>
                    <div>
                        <a
                            href={`mailto:${SITE.EMAIL}`}
                            class="inline-block px-6 py-3 border border-primary text-primary font-semibold uppercase rounded-2xl hover:bg-primary hover:text-button-text transition"
                        >
                            Contact us →
                        </a>
                    </div>
                </div>
            </section>
        </div>
    </div>
</Layout>
