---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Publications | RealityFoundation" active="publications">
  <div class="pb-8 border-b mb-10" style="border-color: var(--color-line);">
    <p class="mb-3 text-xs font-semibold uppercase tracking-widest" style="color: var(--color-muted);">Publications</p>
    <h1>Publications & Outputs</h1>
    <p>
      Academic papers, policy briefs, working papers, and blog posts produced by
      RealityFoundation researchers. All academic outputs are open access.
    </p>
  </div>

  <!-- Filter tabs -->
  <div
    style="display:flex; gap:var(--space-2); flex-wrap:wrap; margin-bottom:var(--space-8); border-bottom:1px solid var(--mono-line); padding-bottom:var(--space-4);"
  >
    <button
      class="btn btn-primary"
      style="font-size:var(--text-xs);"
      onclick="filterPubs('all', this)">All</button
    >
    <button
      class="btn"
      style="font-size:var(--text-xs);"
      onclick="filterPubs('paper', this)">Research Papers</button
    >
    <button
      class="btn"
      style="font-size:var(--text-xs);"
      onclick="filterPubs('policy', this)">Policy Briefs</button
    >
    <button
      class="btn"
      style="font-size:var(--text-xs);"
      onclick="filterPubs('working', this)">Working Papers</button
    >
  </div>

  <!-- Empty state -->
  <div class="flex flex-col items-center text-center py-20 px-8 border-2 border-dashed rounded-lg" style="color: var(--color-muted); border-color: var(--color-line);" id="publications-empty">
    <h3>No publications yet</h3>
    <p>
      The research programme is in its early stages. The first working papers
      are expected in late 2025. Follow the blog for updates as work progresses.
    </p>
    <a href="/blog" class="btn btn-primary">Read the blog</a>
  </div>

  <!-- Publications list (hidden until there are items) -->
  <div
    id="publications-list"
    style="display:none; flex-direction:column; gap:var(--space-4);"
  >
  </div>

  <!-- Forthcoming -->
  <section class="mb-16" style="margin-top:var(--space-16);">
    <div class="mb-8">
      <h2>Forthcoming Work</h2>
      <p>
        Research currently in progress that will produce publications in the
        near term.
      </p>
    </div>
    <div style="display:flex; flex-direction:column; gap:var(--space-3);">
      <div class="card" style="opacity:0.7;">
        <p class="card-eyebrow">Working Paper — Expected Q4 2025</p>
        <h3>Cryptographic Provenance Requirements for Legal Evidentiary Use</h3>
        <p>
          A formal analysis of the conditions under which cryptographically
          timestamped media records meet the evidentiary standards of EU civil
          and criminal procedure.
        </p>
        <div class="card-footer">
          <span class="tag">Theme 01</span>
          <span class="tag">Theme 02</span>
          <span class="tag">Legal</span>
        </div>
      </div>
      <div class="card" style="opacity:0.7;">
        <p class="card-eyebrow">Literature Review — Expected Q1 2026</p>
        <h3>Blockchain Timestamps in EU Insurance Law: A Systematic Review</h3>
        <p>
          A comprehensive review of academic and practitioner literature on the
          use of blockchain-based timestamps in insurance claim adjudication
          across EU member states.
        </p>
        <div class="card-footer">
          <span class="tag">Theme 02</span>
          <span class="tag">Theme 03</span>
          <span class="tag">Insurance</span>
        </div>
      </div>
    </div>
  </section>

  <script>
    function filterPubs(type, btn) {
      document
        .querySelectorAll(".site-shell .btn")
        .forEach((b) => b.classList.remove("btn-primary"));
      btn.classList.add("btn-primary");
    }
  </script>
</BaseLayout>
